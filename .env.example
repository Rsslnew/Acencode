# Telegram Bot Config
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
OWNER_ID=123456789

# Bot Settings
MAX_QUEUE_PER_USER=3
MAX_CONCURRENT_ENCODES=2
FFMPEG_CRF=28
FFMPEG_PRESET=veryfast
VIDEO_CODEC=libx264
AUDIO_CODEC=copy
AUDIO_BITRATE=128k
FFMPEG_TIMEOUT=3600

# SafeLinkU Config
SAFELINKU_API_KEY=your_safelinku_api_key
SAFELINKU_TOKEN=your_safelinku_token
BYPASS_TARGET_URL=https://t.me/your_channel
TOKEN_EXPIRE_SECONDS=86400
BOT_USERNAME=
# Paths (optional - will use defaults if not set)
# BASE_DIR=/app
# DOWNLOAD_PATH=/app/downloads
# OUTPUT_PATH=/app/outputs
# LOG_PATH=/app/logs
